# Copy to .env and fill in.

# Google AI Studio key the reviewer's gemini CLI uses.
GEMINI_API_KEY=

# Static Bearer token for the sam-node control-plane API.
SAM_API_TOKEN=devtoken

# Private code-reviewer image (built/pushed by you).
CODE_REVIEWER_IMAGE=ghcr.io/kaisoz/code-reviewer-mcp:latest

# sam-node image pulled from the internet.
SAM_NODE_IMAGE=ghcr.io/google/sam-node:latest

# Host folder holding the node's enrolled identity.
SAM_DATA_DIR=./sam-data
